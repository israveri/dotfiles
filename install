#!/bin/bash
set -e

run_task() {
    local title="$1"
    shift

    echo "===> $title"
    "$@"
    echo "===> Done."
    echo ""
}

# Forces password prompt
sudo -v

dotdir="$HOME/.dotfiles"

echo "===> Dotfiles"
echo ""

run_task "Updating system and installing dependencies..." \
    bash -c "
	sudo pacman -Syu --noconfirm
	sudo pacman -S --noconfirm --needed git paru
    "

run_task "Setting up dotfiles repository..." \
    bash -c "
	if [ ! -d \"$dotdir\" ]; then
	    git clone https://github.com/israveri/dotfiles \"$dotdir\"
	    git -C \"$dotdir\" remote set-url origin git@github.com:israveri/dotfiles.git
	    git -C \"$dotdir\" remote rename origin github
	fi
    "

run_task "Setting up git submodules..." \
    git -C "$dotdir" submodule update --init

run_task "Installing packages from packages.txt manifest..." \
    paru -S --noconfirm --needed - < "$dotdir/src/packages/manifest.txt"

run_task "Installing Screenshot utility" \
    bash -c "
	if [ ! -d \"$HOME/Workspace/humbleshot\" ]; then
	    mkdir -p \"$HOME/Workspace/\"
	    git clone https://github.com/israveri/humbleshot \"$HOME/Workspace/humbleshot\"
	    git -C \"$HOME/Workspace/humbleshot\" remote set-url origin git@github.com:israveri/humbleshot.git
	    git -C \"$HOME/Workspace/humbleshot\" remote rename origin github
	else
	    echo \"Repo already exists. Skipping.\"
	fi
	ln -sf \"$HOME/Workspace/humbleshot/humbleshot\" \"$dotdir/stow/usr-scripts/dot-local/scripts/humbleshot\"
    "

run_task "Stowing dotfiles..." \
    cd "$dotdir/stow" && stow --dotfiles --dir="$dotdir/stow" --target="$HOME" -v1 */

run_task "Setting up SDDM..." \
    bash -c "
	sudo mkdir -p /etc/sddm.conf.d
	sudo ln -sf "$dotdir/src/applications/sddm/custom.conf" /etc/sddm.conf.d/custom.conf
	setfacl -m u:sddm:x "$HOME"
	setfacl -m u:sddm:r "$HOME/.face.icon"
	sudo cp "$dotdir/src/applications/sddm/hyprland*" /usr/share/wayland-sessions/
    "

run_task "Reloading Hyprland" \
    hyprctl reload

echo ""
echo "✅ Installation complete"
