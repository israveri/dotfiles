#!/bin/bash
set -e

# Forces password prompt
sudo -v

dotdir="$HOME/.dotfiles"

echo "===> Dotfiles"
echo ""

echo "===> Updating system and installing dependencies..."
sudo pacman -Syu
sudo pacman -S --noconfirm --needed git paru
echo "===> Done."
echo ""

echo "===> Setting up dotfiles repository..."
if [ ! -d "$dotdir" ]; then
    git clone https://github.com/israveri/dotfiles "$dotdir"
    git -C "$dotdir" remote set-url origin git@github.com:israveri/dotfiles.git
else
    echo "===> Repository already present. Skipping clone."
fi
echo "===> Done."
echo ""

echo "===> Setting up git submodules..."
git -C "$dotdir" submodule update --init
echo "===> Done."
echo ""

echo "===> Installing packages from packages.txt manifest..."
paru -S --noconfirm --needed - < "$dotdir/src/packages.txt"
echo "===> Done."
echo ""

echo "===> Stowing dotfiles..."
cd "$dotdir/stow" && stow --dotfiles --dir="$dotdir/stow" --target="$HOME" -v1 */
echo "===> Done."
echo ""

echo "===> Reloading Hyprland"
hyprctl reload
echo "===> Done."
echo ""

echo ""
echo "✅ Installation complete"
