[Unit]
Description=Postgres database for Immich
After=photos-pod.service

[Install]
WantedBy=default.target

[Service]
Restart=always

[Container]
ContainerName=photos-postgres
Image=ghcr.io/immich-app/postgres:14-vectorchord0.4.3-pgvectors0.2.0@sha256:bcf63357191b76a916ae5eb93464d65c07511da41e3bf7a8416db519b40b1c23

EnvironmentFile=%h/.config/containers/systemd/environments/photos.env
Environment=POSTGRES_INITDB_ARGS=--data-checksums

Volume=photos-postgres.volume:/var/lib/postgresql/data
ShmSize=128mb

HealthCmd=pg_isready --dbname="$${POSTGRES_DB}" --username="$${POSTGRES_USER}" || exit 1
HealthInterval=30s
HealthRetries=3

Pod=photos.pod
