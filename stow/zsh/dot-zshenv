# Baseline PATH variable
export PATH="$HOME/.local/scripts:$HOME/.local/bin:/usr/local/bin:/usr/bin:/bin"

# XDG Directory Specification
export XDG_CONFIG_HOME="$HOME/.config"
export XDG_DATA_HOME="$HOME/.local/share"
export XDG_CACHE_HOME="$HOME/.cache"
export XDG_STATE_HOME="$HOME/.local/state/"
export XDG_RUNTIME_DIRS="/run/user/$UID"

export ZDOTDIR="$HOME"
export TERM="xterm-256color"

export EDITOR="nvim"
export VISUAL="nvim"

export HISTCONTROL="ignoreboth"
export HISTFILE="$XDG_CONFIG_HOME/zsh/.zhistory"
export HISTSIZE=1000000
export MANPAGER='nvim +Man!'
export SAVEHIST=1000000

# Load environment
fpath=("${XDG_CONFIG_HOME}/zsh/functions" $fpath)
autoload -Uz parse_env load_env
load_env

# Application specifics

# starship
export STARSHIP_CONFIG="$XDG_CONFIG_HOME/starship/config.toml"
