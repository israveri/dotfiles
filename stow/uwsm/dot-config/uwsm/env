# See https://wiki.hypr.land/Configuring/Environment-variables/

#
# All environment vars EXCEPT ones starting with HYPR* and AQ_*
# must be defined here
#

# Adds custom scripts to PATH
export PATH="$PATH:$HOME/.local/scripts"

# Wayland stuff
export GDK_BACKEND="wayland,x11,*"
export SDL_VIDEODRIVER="wayland"
export MOZ_ENABLE_WAYLAND="1"
export ELECTRON_OZONE_PLATFORM_HINT="wayland"
export OZONE_PLATFORM="wayland"
export CLUTTER_BACKEND"wayland"
export QT_QPA_PLATFORM="wayland;xcb"
export QT_AUTO_SCREEN_SCALE_FACTOR="1"
export QT_WAYLAND_DISABLE_WINDOWDECORATION="1"
export QT_QPA_PLATFORMTHEME="qt6ct"
export XDG_SESSION="wayland"

# Allow better screen sharing support (Meet, Zoom, Discord, etc)
export XDG_CURRENT_DESKTOP="Hyprland"
export XDG_SESSION_DESKTOP="Hyprland"
export XDG_SESSION_TYPE="wayland"

# Use XCompose file
export XCOMPOSEFILE="~/.XCompose"

# Gaming optimizations
export PROTON_FSR4_UPGRADE=1
export PROTON_FSR4_RDNA3_UPGRADE=1
export PROTON_NO_WM_DECORATION=1
export PROTON_USE_NTSYNC=1
export PROTON_LOCAL_SHADER_CACHE=1
export ENABLE_LAYER_MESA_ANTI_LAG=1

# Allows game metrics universally (for Vulkan games)
# Might have to run mangohud directly on Steam/Lutris for OpenGL
# SHIFT_R + F12 to toggle overlay
export MANGOHUD=1

# Emulation Station config dir setup
export ESDE_APPDATA_DIR="$XDG_CONFIG_HOME/ES-DE"

# AI API keys
export NOCTALIA_AP_GOOGLE_API_KEY=$(head -n 1 ~/.dotfiles/src/assets/apikeys/gemini.txt | xargs)
