{
  "theme": "dark",
  "defaultProvider": "ollama-cloud",
  "defaultModel": "minimax-m2.1",
  "quietStartup": false,
  "collapseChangelog": true,
  "hideThinkingBlock": false,
  "defaultThinkingLevel": "medium",
  "thinkingBudgets": {
    "low": 1024,
    "medium": 4096,
    "high": 10240,
    "max": 32768
  },
  "enabledModels": [
      "ollama/gemma4:e4b",
      "ollama/gemma4:12b",
      "ollama/qwen3.5:9b"
  ],
  "skills": [
    "~/.config/agents/skills",
    "~/.claude/skills",
    "~/.codex/skills",
    "../.claude/skills"
  ],
  "nmpCommand": [
    "mise",
    "exec",
    "npm@latest",
    "--",
    "npm"
  ],
  "lastChangelogVersion": "0.79.1",
  "packages": [
    "npm:context-mode",
    "npm:pi-search-hub",
    "npm:pi-ollama-cloud"
  ]
}
